# OpenRouter (for chat AI)
VITE_OPENROUTER_API_KEY=sk-or-v1-...

# Stripe (publishable key only - used in frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# API base URL for checkout + enhance.
# Dev: leave empty to use Vite proxy (run "npm run dev:full").
# Production: REQUIRED — set to your backend URL, e.g. https://api.yourdomain.com
# VITE_API_URL=http://localhost:3001
# VITE_API_URL=https://api.yourdomain.com
